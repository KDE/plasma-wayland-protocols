<?xml version="1.0" encoding="UTF-8"?>
<protocol name="shadow">
  <copyright><![CDATA[
    SPDX-FileCopyrightText: 2015 Martin Gräßlin

    SPDX-License-Identifier: LGPL-2.1-or-later
  ]]></copyright>
  <interface name="org_kde_kwin_shadow_manager" version="3">
      <request name="create">
          <arg name="id" type="new_id" interface="org_kde_kwin_shadow"/>
          <arg name="surface" type="object" interface="wl_surface"/>
      </request>
      <request name="unset" deprecated-since="3">
          <description summary="remove the drop shadow">
              Removes the drop shadow.

              Since version 3, this request is deprecated in favor of
              org_kde_kwin_shadow.destroy.
          </description>
          <arg name="surface" type="object" interface="wl_surface"/>
      </request>
      <request name="destroy" type="destructor" since="2">
          <description summary="Destroy the org_kde_kwin_shadow_manager">
              Destroy the org_kde_kwin_shadow_manager object.
          </description>
      </request>
  </interface>
  <interface name="org_kde_kwin_shadow" version="3">
      <request name="commit">
      </request>
      <request name="attach_left">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="attach_top_left">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="attach_top">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="attach_top_right">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="attach_right">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="attach_bottom_right">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="attach_bottom">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="attach_bottom_left">
          <arg name="buffer" type="object" interface="wl_buffer"/>
      </request>
      <request name="set_left_offset">
          <arg name="offset" type="fixed"/>
      </request>
      <request name="set_top_offset">
          <arg name="offset" type="fixed"/>
      </request>
      <request name="set_right_offset">
          <arg name="offset" type="fixed"/>
      </request>
      <request name="set_bottom_offset">
          <arg name="offset" type="fixed"/>
      </request>
      <request name="destroy" type="destructor" since="2">
          <description summary="Destroy the org_kde_kwin_shadow">
              Destroy the org_kde_kwin_shadow object. The change will take
              effect after wl_surface.commit.
          </description>
      </request>
  </interface>
</protocol>
